{
  "version": 2,
  "builds": [
    {
      "src": "api/match-store.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/match-store",
      "dest": "/api/match-store.js"
    },
    {
      "src": "/api/match-store",
      "dest": "/api/match-store.js"
    },
    {
      "src": "/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    }
  ]
}
